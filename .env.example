# ==========================================
# BACKEND
# ==========================================
PORT=3000
NODE_ENV=development

# URI de conexión a tu cluster de MongoDB Atlas
MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/<nombre_bd>?retryWrites=true&w=majority

# Origen permitido para CORS (URL del frontend)
CORS_ORIGIN=http://localhost:5173

# ==========================================
# FRONTEND (Vite solo expone las variables prefijadas con VITE_)
# ==========================================
VITE_API_URL=http://localhost:3000/api