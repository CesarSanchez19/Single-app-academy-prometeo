# BACKEND
PORT=3000
NODE_ENV=development

# URI de conexión a tu cluster de MongoDB Atlas
MONGODB_URI=mongodb+srv://<db_username>:<db_password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
# Secret para tokens JWT
JWT_SECRET=dev_secret_change_in_production

# FRONTEND
VITE_API_URL=http://localhost:3000/api/v1

# Origen permitido para CORS
CORS_ORIGIN=http://localhost:5173

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev